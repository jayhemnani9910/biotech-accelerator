# LLM Configuration
LLM_PROVIDER=groq  # or openai, github, ollama
LLM_API_KEY=your_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# Search Configuration
SEARCH_PROVIDER=tavily  # or duckduckgo
TAVILY_API_KEY=your_tavily_key_here

# Biotech Data Sources (no API key needed for most)
# PDB_BASE_URL=https://files.rcsb.org
# PUBMED_EMAIL=your_email@example.com  # Required for PubMed API
# UNIPROT_BASE_URL=https://rest.uniprot.org

# Research Parameters
MAX_RECURSION_DEPTH=5
MAX_INVESTIGATIONS_PER_EDGE=2

# Output
OUTPUT_DIR=output
LOG_LEVEL=INFO
